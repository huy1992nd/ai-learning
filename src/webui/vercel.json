{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/write-env-prod.mjs && npm run build",
  "outputDirectory": "dist/webui/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pushup-wrench-ignore.ngrok-free.dev/api/:path*"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": "text/html"
        }
      ],
      "destination": "/index.html"
    }
  ]
}
