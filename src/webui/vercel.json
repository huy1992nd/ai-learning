{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/write-env-prod.mjs && npm run build",
  "outputDirectory": "dist/webui/browser",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": "text/html"
        }
      ],
      "destination": "/index.html"
    }
  ]
}
