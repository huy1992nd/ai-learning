{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/webui/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pushup-wrench-ignore.ngrok-free.dev/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
