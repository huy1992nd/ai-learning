# OpenAI-compatible API (chat + optional Whisper STT fallback)
OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
OPENAI_API_KEY=your-api-key-here
OPENAI_DEPLOYMENT=gpt-4o-mini
# Tuỳ chọn: STT bằng Whisper trên cùng resource khi mô hình HF thất bại
OPENAI_STT_DEPLOYMENT=

# Mô hình Hugging Face cho STT (multimodal Gemma-4; tự tải vào thư mục gốc project /models/...)
# HF_TOKEN nếu repo gated. HF_OFFLINE=1: chỉ dùng file sẵn có, không gọi mạng.
HF_SPEECH_MODEL_ID=google/gemma-4-E4B-it
# HF_SPEECH_MODEL_LOCAL_DIR=
# HF_TOKEN=
# HF_OFFLINE=0

# TTS: edge-tts (mô hình HF phía trên không tổng hợp giọng)
# AUDIO_TTS_ENGINE=auto
# SPEECH_TTS_EDGE_VOICE=vi-VN-HoaiMyNeural
# PREFER_HF_LOCAL_STT=1

# Chat behavior
SYSTEM_PROMPT=You are a helpful assistant.

# MedAssist UC-03 disclaimer (BR-01)
MEDICAL_DISCLAIMER=This information is for reference only and does not replace a professional medical diagnosis. Always consult a qualified healthcare provider.

# Session store
SESSION_TTL_SECONDS=1800
SESSION_MAX_MESSAGES=20

# CORS (comma-separated list) — thêm URL FE Vercel khi demo qua ngrok
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,https://ai-learning-git-main-huy1992nds-projects.vercel.app,https://ai-learning-web.vercel.app,https://ai-learning-web-git-main-huy1992nds-projects.vercel.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# SQLite (dummy/medassist.db — chạy `python dummy/seed.py` trong src/api để tạo file)
SQLITE_DATABASE_PATH=dummy/medassist.db

# UC-05 — link form đăng ký (Angular)
FRONTEND_BASE_URL=http://localhost:4200

# UC-09 JWT (đổi secret khi triển khai)
JWT_SECRET=change-me-in-production-use-long-random-secret
JWT_EXPIRE_MINUTES=120

# Nice-to-have — Teams Incoming Webhook sau khi đặt lịch
TEAMS_WEBHOOK_URL=

# Embedding triage + Chroma
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_ENDPOINT=
OPENAI_EMBEDDING_API_KEY=
CHROMA_PERSIST_DIR=dummy/chroma_store
# Tuỳ chọn — thư mục lưu file upload KB admin; trên Vercel dùng /tmp (filesystem bundle thường chỉ đọc)
# KB_UPLOAD_DIR=/tmp/kb_uploads
TRIAGE_EMBEDDING_TOP_K=5
TRIAGE_EMBEDDING_CONFIDENCE_DISTANCE=0.25

# --- Vercel / serverless (SQLite + Chroma ghi được; dữ liệu /tmp không bền giữa các instance) ---
# SQLITE_DATABASE_PATH=/tmp/medassist.db
# CHROMA_PERSIST_DIR=/tmp/chroma_store
# KB_UPLOAD_DIR=/tmp/kb_uploads
# PREFER_HF_LOCAL_STT=0
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:4200
